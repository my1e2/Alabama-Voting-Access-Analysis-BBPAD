"10" = "#08519c",
"15" = "#2171b5",
"20" = "#4292c6",
"30" = "#6baed6"
)
create_isochrone_map <- function(minutes) {
iso_subset <- isochrones[isochrones$time_minutes == minutes, ]
ggplot() +
annotation_map_tile(type = "osm", zoom = 11) +
geom_sf(data = iso_subset,
