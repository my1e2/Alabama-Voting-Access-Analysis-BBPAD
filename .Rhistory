library(sf)
library(ggplot2)
library(ggspatial)
library(patchwork)
# Load data
isochrones <- st_read("data/outputs/polling_isochrones_all.geojson")
polling <- st_read("data/polling/processed/polling_places_montgomery_2020.geojson")
# Transform to Web Mercator for better basemap compatibility
isochrones <- st_transform(isochrones, 3857)
polling <- st_transform(polling, 3857)
# Define clean, professional colors
time_colors <- c(
"5"  = "#2171b5",
"10" = "#4292c6",
"15" = "#6baed6",
"20" = "#9ecae1",
"30" = "#c6dbef"
)
# Function to create a single isochrone map
create_isochrone_map <- function(minutes) {
iso_subset <- isochrones[isochrones$time_minutes == minutes, ]
ggplot() +
# Basemap - using osm tiles directly (more reliable)
layer_spatial(
annotation_map_tile(type = "osm", zoom = 11),
alpha = 1
) +
# Isochrone polygons
geom_sf(data = iso_subset,
aes(fill = as.character(time_minutes)),
alpha = 0.3,
color = time_colors[as.character(minutes)],
linewidth = 0.3) +
# Polling places
geom_sf(data = polling,
color = "#2c3e50",
size = 2,
shape = 21,
fill = "white",
stroke = 0.8) +
scale_fill_manual(values = time_colors, guide = "none") +
labs(title = paste(minutes, "-Minute Walk"),
subtitle = paste(nrow(iso_subset), "polling places")) +
theme_void() +
theme(
plot.title = element_text(size = 11, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 8, hjust = 0.5, color = "grey40"),
panel.border = element_rect(color = "grey70", fill = NA, linewidth = 0.5)
)
}
# Create individual maps
map_5  <- create_isochrone_map(5)
library(sf)
library(ggplot2)
library(ggspatial)
library(patchwork)
# Load data
isochrones <- st_read("data/outputs/polling_isochrones_all.geojson")
polling <- st_read("data/polling/processed/polling_places_montgomery_2020.geojson")
# Transform to Web Mercator for basemap compatibility
isochrones <- st_transform(isochrones, 3857)
polling <- st_transform(polling, 3857)
# Define clean, professional colors
time_colors <- c(
"5"  = "#2171b5",
"10" = "#4292c6",
"15" = "#6baed6",
"20" = "#9ecae1",
"30" = "#c6dbef"
)
# Function to create a single isochrone map
create_isochrone_map <- function(minutes) {
iso_subset <- isochrones[isochrones$time_minutes == minutes, ]
ggplot() +
# Basemap - direct annotation_map_tile call (no layer_spatial wrapper)
annotation_map_tile(type = "osm", zoom = 11) +
# Isochrone polygons
geom_sf(data = iso_subset,
aes(fill = as.character(time_minutes)),
alpha = 0.3,
color = time_colors[as.character(minutes)],
linewidth = 0.3) +
# Polling places
geom_sf(data = polling,
color = "#2c3e50",
size = 2,
shape = 21,
fill = "white",
stroke = 0.8) +
scale_fill_manual(values = time_colors, guide = "none") +
labs(title = paste(minutes, "-Minute Walk"),
subtitle = paste(nrow(iso_subset), "polling places")) +
theme_void() +
theme(
plot.title = element_text(size = 11, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 8, hjust = 0.5, color = "grey40"),
panel.border = element_rect(color = "grey70", fill = NA, linewidth = 0.5)
)
}
# Create individual maps
map_5  <- create_isochrone_map(5)
map_10 <- create_isochrone_map(10)
map_15 <- create_isochrone_map(15)
map_20 <- create_isochrone_map(20)
map_30 <- create_isochrone_map(30)
# Combine
combined_map <- (map_5 + map_10 + map_15) / (map_20 + map_30 + plot_spacer()) +
plot_annotation(
title = "Walking Isochrones Around Polling Places",
subtitle = "Montgomery County, AL",
theme = theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5, color = "grey40")
)
)
# Save
ggsave("outputs/maps/isochrone_panel_r.png",
combined_map,
width = 16,
height = 12,
dpi = 300)
library(sf)
library(ggplot2)
library(ggspatial)
library(patchwork)
# Load data
isochrones <- st_read("data/outputs/polling_isochrones_all.geojson")
polling <- st_read("data/polling/processed/polling_places_montgomery_2020.geojson")
# Transform to Web Mercator
isochrones <- st_transform(isochrones, 3857)
polling <- st_transform(polling, 3857)
# Darker, more visible colors with better contrast
time_colors <- c(
"5"  = "#08519c",   # dark blue
"10" = "#2171b5",   # medium-dark blue
"15" = "#4292c6",   # medium blue
"20" = "#74a9cf",   # light blue
"30" = "#bdc9e1"    # very light blue-grey
)
# Border colors (darker than fill for visibility)
border_colors <- c(
"5"  = "#063a73",
"10" = "#08519c",
"15" = "#2171b5",
"20" = "#4292c6",
"30" = "#6baed6"
)
create_isochrone_map <- function(minutes) {
iso_subset <- isochrones[isochrones$time_minutes == minutes, ]
ggplot() +
annotation_map_tile(type = "osm", zoom = 11) +
geom_sf(data = iso_subset,
aes(fill = as.character(time_minutes)),
alpha = 0.35,                              # slightly more opaque
color = border_colors[as.character(minutes)],
linewidth = 0.4) +
geom_sf(data = polling,
color = "#1a1a1a",                         # nearly black for contrast
size = 1.2,                                # much smaller points
shape = 21,
fill = "#e34a33",                          # red-orange fill (stands out)
stroke = 0.5) +
scale_fill_manual(values = time_colors, guide = "none") +
labs(title = paste(minutes, "-Minute Walk"),
subtitle = paste(nrow(iso_subset), "polling places")) +
coord_sf(expand = FALSE) +                         # prevents extra padding
theme_void() +
theme(
plot.title = element_text(size = 11, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 8, hjust = 0.5, color = "grey40"),
panel.border = element_rect(color = "grey70", fill = NA, linewidth = 0.5)
)
}
map_5  <- create_isochrone_map(5)
map_10 <- create_isochrone_map(10)
map_15 <- create_isochrone_map(15)
map_20 <- create_isochrone_map(20)
map_30 <- create_isochrone_map(30)
combined_map <- (map_5 + map_10 + map_15) / (map_20 + map_30 + plot_spacer()) +
plot_annotation(
title = "Walking Isochrones Around Polling Places",
subtitle = "Montgomery County, AL",
theme = theme(
plot.title = element_text(size = 16, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 12, hjust = 0.5, color = "grey40")
)
)
ggsave("outputs/maps/isochrone_panel_r.png",
combined_map,
width = 16,
height = 12,
dpi = 300)
library(sf)
library(ggplot2)
library(ggspatial)
library(dplyr)
# Load data
isochrones <- st_read("data/outputs/polling_isochrones_all.geojson")
polling <- st_read("data/polling/processed/polling_places_montgomery_2020.geojson")
# Transform to Web Mercator
isochrones <- st_transform(isochrones, 3857)
polling <- st_transform(polling, 3857)
# Make time_minutes a factor with ordered levels for clean facet labels
isochrones$time_label <- factor(
isochrones$time_minutes,
levels = c(5, 10, 15, 20, 30),
labels = c("5-Minute Walk", "10-Minute Walk", "15-Minute Walk",
"20-Minute Walk", "30-Minute Walk")
)
# Create the faceted map
ggplot() +
# Basemap
annotation_map_tile(type = "osm", zoom = 11) +
# Isochrone polygons - color by time interval
geom_sf(data = isochrones,
aes(fill = time_label),
alpha = 0.3,
color = "grey40",
linewidth = 0.2) +
# Polling places
geom_sf(data = polling,
color = "#1a1a1a",
size = 0.8,
shape = 21,
fill = "#e34a33",
stroke = 0.3) +
# Facet by time interval
facet_wrap(~ time_label, ncol = 3) +
# Professional color palette
scale_fill_manual(
values = c(
"5-Minute Walk"  = "#08519c",
"10-Minute Walk" = "#2171b5",
"15-Minute Walk" = "#4292c6",
"20-Minute Walk" = "#74a9cf",
"30-Minute Walk" = "#bdc9e1"
),
guide = "none"
) +
# Labels
labs(
title = "Walking Isochrones Around Polling Places",
subtitle = "Montgomery County, AL",
caption = "Each panel shows walkable area from all 49 polling places for a given time threshold"
) +
theme_void() +
theme(
plot.title = element_text(size = 18, face = "bold", hjust = 0.5),
plot.subtitle = element_text(size = 13, hjust = 0.5, color = "grey40"),
plot.caption = element_text(size = 9, hjust = 0.5, color = "grey60"),
strip.text = element_text(size = 12, face = "bold"),
panel.border = element_rect(color = "grey80", fill = NA, linewidth = 0.5),
panel.spacing = unit(0.5, "lines")
)
# Save at a larger size for faceted layout
ggsave("outputs/maps/isochrone_faceted_r.png",
width = 18,
height = 12,
dpi = 300)
library(sf)
library(ggplot2)
library(ggspatial)
library(patchwork)
# Load data
isochrones <- st_read("data/outputs/polling_isochrones_all.geojson")
